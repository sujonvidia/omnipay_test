NODE_ENV=development
APP_TITLE=OmniPay
APP_DOMAIN="omnipay.freeli.io"
APP_SUPPORT_EMAIL="support@yourapp.com"

# JWT Secret Keys — use long random strings in production
JWT_SECRET_KEY=replace_with_a_long_random_secret
REFRESH_JWT_SECRET_KEY=replace_with_a_different_long_random_secret

# SendGrid (OTP + password reset emails)
SENDGRID_API_KEY=SG.replace_with_your_sendgrid_api_key
SENDGRID_SENDER_EMAIL="no-reply@yourapp.com"

# Client (Vite) base URL — used in email links
CLIENT_BASE_URL=http://localhost:3000/

# API Server
API_SERVER_PORT=4101

# MongoDB — own database, separate from Workfreeli's
MONGO_DB_URL='mongodb://127.0.0.1:27017/omnipay_finance'

# CardPointe / Fiserv payment gateway
CARDPOINTE_BASE_URL=https://fts-uat.cardconnect.com/cardconnect/rest
CARDPOINTE_MERCHANT_ID=your_merchant_id
CARDPOINTE_SURCHARGE_MID=your_surcharge_mid
CARDPOINTE_USERNAME=your_cardpointe_username
CARDPOINTE_PASSWORD=your_cardpointe_password

# CardPointe Bolt Terminal API (card-present)
BOLT_TERMINAL_URL=https://bolt-uat.cardpointe.com/api/
BOLT_AUTH_KEY=your_bolt_auth_key

# CardPointe Reporting Portal
CARDPOINTE_REPORTING_URL=https://cardpointe-uat.cardconnect.com
CARDPOINTE_REPORTING_USERNAME=your_reporting_username
CARDPOINTE_REPORTING_PASSWORD=your_reporting_password
